{
  "version": "1.0.0",
  "gateway": {
    "primary": "https://api.opencdp.io/gateway/data-gateway",
    "fallbacks": [
      "https://api.opencdp.com/gateway/data-gateway",
      "https://api.opencdp.xyz/gateway/data-gateway"
    ]
  },
  "vectors": [
    {
      "id": "identify-basic",
      "method": "POST",
      "path": "/v1/persons/identify",
      "body": {
        "identifier": "user_123",
        "properties": { "plan": "pro", "name": "Alice" }
      }
    },
    {
      "id": "track-basic",
      "method": "POST",
      "path": "/v1/persons/track",
      "body": {
        "identifier": "user_123",
        "eventName": "purchase",
        "properties": { "amount": 99.9 }
      }
    },
    {
      "id": "register-device-android",
      "method": "POST",
      "path": "/v1/persons/registerDevice",
      "body": {
        "identifier": "user_123",
        "deviceId": "device-abc",
        "platform": "android",
        "fcmToken": "fcm-token-xyz",
        "model": "Pixel 8",
        "osVersion": "14",
        "appVersion": "1.0.0"
      }
    },
    {
      "id": "ping",
      "method": "GET",
      "path": "/v1/health/ping",
      "body": null
    }
  ]
}
