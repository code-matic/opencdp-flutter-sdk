CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/AnalyticsSwiftCIO" "${PODS_CONFIGURATION_BUILD_DIR}/CustomerIOCommon" "${PODS_CONFIGURATION_BUILD_DIR}/CustomerIODataPipelines" "${PODS_CONFIGURATION_BUILD_DIR}/CustomerIOMessagingInApp" "${PODS_CONFIGURATION_BUILD_DIR}/CustomerIOMessagingPush" "${PODS_CONFIGURATION_BUILD_DIR}/CustomerIOTrackingMigration" "${PODS_CONFIGURATION_BUILD_DIR}/JSONSafeEncoding" "${PODS_CONFIGURATION_BUILD_DIR}/Sovran" "${PODS_CONFIGURATION_BUILD_DIR}/customer_io" "${PODS_CONFIGURATION_BUILD_DIR}/device_info_plus" "${PODS_CONFIGURATION_BUILD_DIR}/open_cdp_flutter_sdk" "${PODS_CONFIGURATION_BUILD_DIR}/package_info_plus" "${PODS_CONFIGURATION_BUILD_DIR}/shared_preferences_foundation"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/AnalyticsSwiftCIO/CioAnalytics.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CustomerIOCommon/CioInternalCommon.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CustomerIODataPipelines/CioDataPipelines.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CustomerIOMessagingInApp/CioMessagingInApp.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CustomerIOMessagingPush/CioMessagingPush.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CustomerIOTrackingMigration/CioTrackingMigration.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/JSONSafeEncoding/JSONSafeEncoding.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/Sovran/Sovran.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/customer_io/customer_io.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/device_info_plus/device_info_plus.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/open_cdp_flutter_sdk/open_cdp_flutter_sdk.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/package_info_plus/package_info_plus.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/shared_preferences_foundation/shared_preferences_foundation.framework/Headers"
LD_RUNPATH_SEARCH_PATHS = $(inherited) /usr/lib/swift
LIBRARY_SEARCH_PATHS = $(inherited) $(TOOLCHAIN_DIR)/usr/lib/swift/$(PLATFORM_NAME)/ $(SDKROOT)/usr/lib/swift
OTHER_LDFLAGS = $(inherited) -framework "CioAnalytics" -framework "CioDataPipelines" -framework "CioInternalCommon" -framework "CioMessagingInApp" -framework "CioMessagingPush" -framework "CioTrackingMigration" -framework "JSONSafeEncoding" -framework "Sovran" -framework "customer_io" -framework "device_info_plus" -framework "open_cdp_flutter_sdk" -framework "package_info_plus" -framework "shared_preferences_foundation"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
